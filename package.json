{
  "name": "clickup-discord-integration",
  "version": "2.0.0",
  "description": "Discord notifications for ClickUp leave form submissions (NestJS + Lambda)",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json --outDir dist",
    "start": "npm run build && node run.js",
    "start:dev": "npm run build && npx concurrently -k \"tsc -p tsconfig.json -w --outDir dist\" \"npx wait-on dist/main.js -t 60000 && npx nodemon --watch dist --ext js --exec 'node dist/main.js'\"",
    "serve": "node dist/main.js",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main.js",
    "lambda:build": "nest build && node -e \"const fs=require('fs');fs.copyFileSync('package.json','dist/package.json')\" && cd dist && npm install --omit=dev && cd .. && powershell Compress-Archive -Path dist/* -DestinationPath lambda.zip -Force",
    "lambda:invoke": "node -e \"require('./dist/lambda').handler({ schedule: 'daily' }).then(r => console.log(r))\""
  },
  "dependencies": {
    "@discordjs/rest": "^2.6.0",
    "@nestjs/common": "^11.1.16",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.16",
    "@nestjs/platform-express": "^11.1.16",
    "axios": "^1.6.0",
    "discord-api-types": "^0.38.42",
    "moment-timezone": "^0.6.0",
    "mongodb": "^7.1.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.16",
    "@types/express": "^4.17.17",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.3.0",
    "concurrently": "^8.2.0",
    "nodemon": "^3.0.0",
    "typescript": "^5.1.0",
    "wait-on": "^7.0.0"
  },
  "overrides": {
    "ajv": "^8.18.0",
    "glob": "^10.5.0",
    "lodash": "^4.17.23",
    "tmp": "^0.2.2"
  },
  "keywords": [
    "clickup",
    "discord",
    "webhook",
    "notifications",
    "leave-management",
    "nestjs",
    "lambda"
  ],
  "author": "",
  "license": "MIT"
}
